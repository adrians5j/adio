{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "coverage/"
  ],
  "rules": {
    "curly": "off",
    "no-unused-vars": ["warn", { "caughtErrorsIgnorePattern": "^_" }]
  }
}
