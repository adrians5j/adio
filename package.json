{
    "name": "adio",
    "version": "2.1.0",
    "type": "module",
    "description": "Checks if the dependencies in package.json and in the actual code are synced.",
    "main": "src/index.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/adrians5j/adio.git"
    },
    "author": "Adrian Smijulj",
    "contributors": [
        "Pavel Denisjuk <pavel@webiny.com>"
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/adrians5j/adio/issues"
    },
    "keywords": [
        "dependencies",
        "deps",
        "in order",
        "synced",
        "checked",
        "check"
    ],
    "homepage": "https://github.com/adrians5j/adio#readme",
    "scripts": {
        "cz": "git-cz",
        "build": "babel src --out-dir dist --source-maps --ignore **/*.test.js",
        "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
        "test:coverage": "cross-env COVERAGE=true yarn test",
        "test:coverage:coveralls": "yarn test:coverage && cat ./coverage/lcov.info | coveralls",
        "release": "yarn semantic-release",
        "lint-staged": "lint-staged",
        "semantic-release": "semantic-release",
        "prettier": "prettier --check \"**/*.{js,json}\"",
        "prettier:fix": "prettier --write \"**/*.{js,json}\""
    },
    "pre-commit": [
        "lint-staged"
    ],
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "bin": "src/bin/adio.js",
    "lint-staged": {
        "**/*.js": [
            "prettier --write",
            "eslint --fix",
            "jest --findRelatedTests",
            "git add"
        ]
    },
    "dependencies": {
        "@babel/parser": "^7.29.2",
        "@babel/traverse": "^7.29.0",
        "chalk": "^5.6.2",
        "cosmiconfig": "^9.0.1",
        "glob": "^13.0.6",
        "lodash.get": "^4.4.2",
        "relative-require-regex": "^1.0.1",
        "require-package-name": "^2.0.1",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "concurrently": "^9.2.1",
        "coveralls": "^3.1.1",
        "cross-env": "^10.1.0",
        "cz-conventional-changelog": "^3.3.0",
        "extract-zip": "^2.0.1",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "semantic-release": "^25.0.3"
    },
    "packageManager": "yarn@4.13.0"
}
