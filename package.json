{
    "name": "adio",
    "version": "3.0.0",
    "type": "module",
    "description": "Checks if the dependencies in package.json and in the actual code are synced.",
    "main": "src/index.js",
    "exports": {
        ".": {
            "import": "./src/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "src/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/adrians5j/adio.git"
    },
    "author": "Adrian Smijulj",
    "contributors": [
        "Pavel Denisjuk <pavel@webiny.com>"
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/adrians5j/adio/issues"
    },
    "keywords": [
        "dependencies",
        "deps",
        "in order",
        "synced",
        "checked",
        "check"
    ],
    "homepage": "https://github.com/adrians5j/adio#readme",
    "scripts": {
        "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
        "test:coverage": "COVERAGE=true yarn test",
        "release": "yarn semantic-release",
        "lint-staged": "lint-staged",
        "semantic-release": "semantic-release",
        "format": "oxfmt --check src/",
        "lint": "oxlint src/"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "bin": "src/bin/adio.js",
    "lint-staged": {
        "**/*.js": [
            "oxfmt",
            "oxlint --fix",
            "jest --findRelatedTests",
            "git add"
        ]
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "cosmiconfig": "^9.0.1",
        "glob": "^13.0.6",
        "oxc-parser": "^0.129.0"
    },
    "devDependencies": {
        "extract-zip": "^2.0.1",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.3",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "semantic-release": "^25.0.3"
    },
    "packageManager": "yarn@4.13.0"
}
